{
  "id": "asr",
  "name": "Qwen ASR",
  "version": "1.0.0",
  "runtime": "wsl-docker",
  "runtimeConfig": {
    "containerName": "server-zushengcc-host-services-host-asr-service-1",
    "port": 5001,
    "timeoutMs": 600000,
    "wslDistro": "Ubuntu-22.04"
  },
  "capabilities": [
    {
      "name": "asr.test",
      "description": "语音识别——测试隔离，不领取生产 asr 任务",
      "inputSchema": {
        "type": "object",
        "required": ["audioUrl"],
        "properties": {
          "audioUrl": { "type": "string" },
          "language": { "type": "string" }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "text": { "type": "string" },
          "files": { "type": "array" }
        }
      }
    }
  ],
  "healthcheck": { "type": "process" }
}
