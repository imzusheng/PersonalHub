{
  "id": "vision",
  "name": "Qwen Vision",
  "version": "1.0.0",
  "runtime": "wsl-docker",
  "runtimeConfig": {
    "containerName": "server-zushengcc-host-services-host-vision-service-1",
    "port": 5002,
    "timeoutMs": 600000,
    "wslDistro": "Ubuntu-22.04"
  },
  "capabilities": [
    {
      "name": "vision",
      "description": "图像识别",
      "inputSchema": {
        "type": "object",
        "required": ["imageUrl"],
        "properties": {
          "imageUrl": { "type": "string" },
          "mode": { "type": "string" },
          "prompt": { "type": "string" },
          "language": { "type": "string" }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "text": { "type": "string" },
          "json": { "type": "object" }
        }
      }
    }
  ],
  "healthcheck": { "type": "process" }
}
