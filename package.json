{
  "name": "personalhub",
  "version": "0.1.1",
  "description": "Open-source personal computer AI Worker Runtime - turns a personal Windows PC into a pluggable, locally-callable, optionally remotely-schedulable AI capability node.",
  "author": "imzusheng",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:electron": "pnpm build:ts && VITE_DEV_SERVER_URL=http://localhost:5173 concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:ts": "tsc -p tsconfig.build.json && node scripts/copy-preload.mjs",
    "build:renderer": "vite build",
    "build": "pnpm build:ts && pnpm build:renderer",
    "pack:win": "node scripts/generate-icons.mjs && pnpm build && electron-builder --win --x64",
    "pack:mac": "pnpm build && electron-builder --mac --x64",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "main": "dist/desktop/main/main.js",
  "build": {
    "appId": "cc.zusheng.personalhub",
    "productName": "PersonalHub",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "pnpm-workspace.yaml"
    ],
    "extraResources": [
      {
        "from": "plugins",
        "to": "plugins"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "imzusheng",
        "repo": "PersonalHub",
        "releaseType": "release"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "PersonalHub-${version}-${arch}.${ext}"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "PersonalHub-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "include": "build/installer.nsh",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PersonalHub"
    },
    "extends": null
  },
  "dependencies": {
    "electron-updater": "6.8.9",
    "fastify": "^5.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  }
}
