{
  "name": "personalhub",
  "version": "0.1.0",
  "description": "Open-source personal computer AI Worker Runtime - turns a personal Windows PC into a pluggable, locally-callable, optionally remotely-schedulable AI capability node.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:electron": "VITE_DEV_SERVER_URL=http://localhost:5173 concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "main": "dist/desktop/main/main.js",
  "dependencies": {
    "fastify": "^5.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  }
}
